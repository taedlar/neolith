{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 28,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "project-default",
            "hidden": true,
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_POSITION_INDEPENDENT_CODE": "ON",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_PROJECT_TOP_LEVEL_INCLUDES": "${sourceDir}/cmake/setup.cmake"
            }
        },
        {
            "name": "msvc-x64",
            "hidden": true,
            "cacheVariables": {
                "BISON_ROOT": "C:/GnuWin32",
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL"
            },
            "vendor": {
                "microsoft.com/VisualStudioSettings/CMake/1.0": {
                    "hostOS": [ "Windows" ],
                    "clangTidyChecks": "llvm-include-order, -modernize-use-override",
                    "enableMicrosoftCodeAnalysis": true,
                    "enableClangTidyCodeAnalysis": true
                }
            },
            "architecture": {
              "value": "x64",
              "strategy": "set"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "vs18-x64",
            "description": "Uses Visual Studio 2026 generator, x64 architecture",
            "inherits": ["project-default", "msvc-x64"],
            "generator": "Visual Studio 18 2026"
        },
        {
            "name": "vs16-x64",
            "description": "Uses Visual Studio 2019 generator, x64 architecture",
            "inherits": ["project-default", "msvc-x64"],
            "generator": "Visual Studio 16 2019"
        },
        {
            "name": "clangcl-x64",
            "description": "Uses ClangCL compiler, x64 architecture",
            "inherits": ["project-default", "msvc-x64"],
            "generator": "Visual Studio 16 2019",
            "toolset": {
              "value": "ClangCL",
              "strategy": "set"
            }
        },
        {
            "name": "linux-default",
            "hidden": true,
            "generator": "Ninja Multi-Config",
            "vendor": {
                "microsoft.com/VisualStudioSettings/CMake/1.0": {
                  "hostOS": [ "Linux" ]
                }
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "linux-gcc",
            "description": "Uses Ninja Multi-Config generator, GCC compiler",
            "inherits": ["project-default", "linux-default"],
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++"
            }
        },
        {
            "name": "linux-clang",
            "description": "Uses Ninja Multi-Config generator, Clang compiler",
            "inherits": ["project-default", "linux-default"],
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            }
        },
        {
            "name": "macos-default",
            "hidden": true,
            "generator": "Ninja Multi-Config",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "macos-arm64",
            "description": "Uses Ninja Multi-Config generator, ARM64 architecture",
            "inherits": ["project-default", "macos-default"],
            "cacheVariables": {
                "CMAKE_OSX_ARCHITECTURES": "arm64"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "dev-vs18-x64",
            "description": "Debug Build (build modified files)",
            "configurePreset": "vs18-x64",
            "configuration": "Debug",
            "targets": ["ALL_BUILD"]
        },
        {
            "name": "pr-vs18-x64",
            "description": "Pull-Request Validation Build (build modified files)",
            "inherits": ["dev-vs18-x64"],
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "ci-vs18-x64",
            "description": "Continous Integration Build (rebuild all)",
            "inherits": ["pr-vs18-x64"],
            "cleanFirst": true
        },
        {
            "name": "dev-vs16-x64",
            "description": "Debug Build (build modified files)",
            "configurePreset": "vs16-x64",
            "configuration": "Debug",
            "targets": ["ALL_BUILD"]
        },
        {
            "name": "pr-vs16-x64",
            "description": "Pull-Request Validation Build (build modified files)",
            "inherits": ["dev-vs16-x64"],
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "ci-vs16-x64",
            "description": "Continous Integration Build (rebuild all)",
            "inherits": ["pr-vs16-x64"],
            "cleanFirst": true
        },
        {
            "name": "dev-clangcl-x64",
            "description": "Debug Build (build modified files)",
            "configurePreset": "clangcl-x64",
            "configuration": "Debug",
            "targets": ["ALL_BUILD"]
        },
        {
            "name": "pr-clangcl-x64",
            "description": "Pull-Request Validation Build (build modified files)",
            "inherits": ["dev-clangcl-x64"],
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "ci-clangcl-x64",
            "description": "Continous Integration Build (rebuild all)",
            "inherits": ["pr-clangcl-x64"],
            "cleanFirst": true
        },
        {
            "name": "dev-linux-gcc",
            "description": "Debug Build (build modified files)",
            "configurePreset": "linux-gcc",
            "configuration": "Debug",
            "targets": ["all"]
        },
        {
            "name": "pr-linux-gcc",
            "description": "Pull-Request Validation Build (build modified files)",
            "inherits": ["dev-linux-gcc"],
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "ci-linux-gcc",
            "description": "Continous Integration Build (rebuild all)",
            "inherits": ["pr-linux-gcc"],
            "cleanFirst": true
        },
        {
            "name": "dev-linux-clang",
            "description": "Debug Build (build modified files)",
            "configurePreset": "linux-clang",
            "configuration": "Debug",
            "targets": ["all"]
        },
        {
            "name": "pr-linux-clang",
            "description": "Pull-Request Validation Build (build modified files)",
            "inherits": ["dev-linux-clang"],
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "ci-linux-clang",
            "description": "Continous Integration Build (rebuild all)",
            "inherits": ["pr-linux-clang"],
            "cleanFirst": true
        },
        {
            "name": "dev-macos-arm64",
            "description": "Debug Build (build modified files)",
            "configurePreset": "macos-arm64",
            "configuration": "Debug",
            "targets": ["all"]
        },
        {
            "name": "pr-macos-arm64",
            "description": "Pull-Request Validation Build (build modified files)",
            "inherits": ["dev-macos-arm64"],
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "ci-macos-arm64",
            "description": "Continuous Integration Build (rebuild all)",
            "inherits": ["pr-macos-arm64"],
            "cleanFirst": true
        }
    ],
    "testPresets": [
        {
            "name": "ut-defaults",
            "hidden": true,
            "execution": {
                "noTestsAction": "ignore"
            }
        },
        {
            "name": "ut-vs18-x64",
            "description": "Run unit-tests for Windows 64-bits architecture",
            "configurePreset": "vs18-x64",
            "inherits": ["ut-defaults"]
        },
        {
            "name": "ut-vs16-x64",
            "description": "Run unit-tests for Windows 64-bits architecture",
            "configurePreset": "vs16-x64",
            "inherits": ["ut-defaults"]
        },
        {
            "name": "ut-clangcl-x64",
            "description": "Run unit-tests for Windows 64-bits architecture",
            "configurePreset": "clangcl-x64",
            "inherits": ["ut-defaults"]
        },
        {
            "name": "ut-linux-gcc",
            "description": "Run unit-tests on Linux",
            "configurePreset": "linux-gcc",
            "inherits": ["ut-defaults"]
        },
        {
            "name": "ut-linux-clang",
            "description": "Run unit-tests on Linux",
            "configurePreset": "linux-clang",
            "inherits": ["ut-defaults"]
        },
        {
            "name": "ut-macos-arm64",
            "description": "Run unit-tests on macOS ARM64",
            "configurePreset": "macos-arm64",
            "inherits": ["ut-defaults"]
        }
    ]
}
